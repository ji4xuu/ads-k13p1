# Salin file ini ke .env lalu isi nilainya:
#   cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
# Buat dulu di PostgreSQL:
#   psql -U postgres -c "CREATE USER iash_user WITH PASSWORD 'iash_pass';"
#   psql -U postgres -c "CREATE DATABASE iash_db OWNER iash_user;"
DATABASE_URL=postgresql://iash_user:iash_pass@localhost:5432/iash_db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Untuk development bisa pakai nilai apapun.
# Untuk production generate dulu:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=ganti-ini-dengan-string-acak-yang-panjang
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Dipakai untuk CORS dan link di email notifikasi.
# Development: biarkan http://localhost:5173
# Production: ganti ke URL Vercel kamu
FRONTEND_URL=http://localhost:5173

# ── File Upload ───────────────────────────────────────────────────────────────
# Development: biarkan "uploads" (folder relatif di dalam backend/)
# Production Railway: /app/uploads (wajib pakai Persistent Volume)
UPLOAD_DIR=uploads

# ── Email Notifikasi (SMTP) ───────────────────────────────────────────────────
# Kosongkan MAIL_USERNAME untuk menonaktifkan email — aman untuk development,
# app tetap berjalan normal tanpa mengirim email.
# Untuk aktifkan: isi dengan Gmail + App Password
# (buat App Password di: https://myaccount.google.com/apppasswords)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@iash.ipb.ac.id
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
